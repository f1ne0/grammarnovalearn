# ===== DATABASE =====
# Neon POOLED connection (host contains "-pooler") — used by the running app.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/grammar_db?sslmode=require"
# Neon DIRECT connection (host WITHOUT "-pooler") — used by prisma migrate.
# Locally you can set this to the same value as DATABASE_URL.
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/grammar_db?sslmode=require"

# ===== AUTH =====
JWT_SECRET="your-super-secret-key-change-in-prod-min-32-chars"
JWT_EXPIRY="24h"
REFRESH_TOKEN_EXPIRY="7d"

# ===== INVITE CODES =====
INVITE_CODE_LENGTH=8
INVITE_EXPIRY_DAYS=30

# ===== APP =====
NODE_ENV="development"
# Local port only. On Render the platform injects PORT and it takes priority.
API_PORT=3000
API_URL="http://localhost:3000"
# In production set this to your Vercel URL (used for CORS). No trailing slash.
FRONTEND_URL="http://localhost:5173"

# ===== AI (GEMINI) =====
GOOGLE_API_KEY="your-gemini-api-key"

# ===== TTS (optional) =====
# Voice options: https://ai.google.dev/gemini-api/docs/speech-generation#voices
TTS_VOICE="Sulafat"

# ===== CLOUDFLARE R2 (for speaking exercise audio) =====
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret"
R2_BUCKET="grammar-platform"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
